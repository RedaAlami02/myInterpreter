# myInterpreter — environment configuration (EXAMPLE / placeholders only)
# Copy to `.env` (and set the same values as Appwrite Cloud Function variables).
# Never commit real values. `.env` is gitignored.

# --- Appwrite (used by the Python Cloud Functions: cloud_function/) ---
APPWRITE_ENDPOINT=https://<region>.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_appwrite_server_api_key   # server key with documents.read/write — keep secret

# --- PHP web frontend ---
# The PHP app reads its server API key from config/secrets.php (gitignored), not from .env.
# Create config/secrets.php from this template:
#   <?php
#   define('APPWRITE_API_KEY', 'your_appwrite_server_api_key');
# The endpoint and project ID are non-secret constants in core/Appwrite.php.
#
# Note: there are NO database credentials — the app uses the Appwrite REST API,
# not a direct MySQL/SQL connection. (migrate.py is a local one-off import tool.)
